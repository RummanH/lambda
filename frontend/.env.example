# Base URL of the NestJS backend (or, later, the API Gateway stage URL)
VITE_API_URL=http://localhost:3000

# From your Cognito User Pool's App Client
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# The Cognito Hosted UI domain you picked, e.g. cognito-demo-yourname
VITE_COGNITO_DOMAIN=your-domain-prefix.auth.us-east-1.amazoncognito.com

# Must exactly match an "Allowed callback URL" / "Allowed sign-out URL"
# configured on the App Client
VITE_APP_URL=http://localhost:5173
